
APP_KEY=base64:GENERATE_ME                 # run `php artisan key:generate` in backend container
APP_URL=http://localhost:8000
APP_DEBUG=false

# Database (used by docker-compose and Laravel)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=tasks_db
DB_USERNAME=tasks_user
DB_PASSWORD=secret

# Optional: change these if you wire up external services
# MAIL_HOST=mailhog
# MAIL_PORT=1025
# REDIS_HOST=redis
